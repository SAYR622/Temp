<Window x:Class="VMS.UI.AccountSettings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Icon="/Images/logo2.png"
        Title="Account Settings"
        Height="450" Width="350"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC"
        ResizeMode="NoResize">

    <Border Padding="25">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0" Text="Account Settings" FontSize="20" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,25"/>

            <!-- Form -->
            <StackPanel Grid.Row="1">

                <TextBox x:Name="txtName" 
                         materialDesign:HintAssist.Hint="Full Name"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         FontSize="14" Margin="0,0,0,20"/>

                <ComboBox x:Name="cmbGender" 
                          materialDesign:HintAssist.Hint="Gender"
                          Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                          FontSize="14" Margin="0,0,0,20">
                    <ComboBoxItem Content="Male"/>
                    <ComboBoxItem Content="Female"/>
                </ComboBox>

                <TextBox x:Name="txtContact" 
                         materialDesign:HintAssist.Hint="Contact Number"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         FontSize="14" Margin="0,0,0,20"/>

                <TextBox x:Name="txtPassword" 
                         materialDesign:HintAssist.Hint="New Password"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         FontSize="14" Margin="0,0,0,20"/>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button x:Name="btnCancel" Content="CANCEL" Style="{StaticResource MaterialDesignOutlinedButton}" Width="90" Margin="0,0,10,0" Click="btnCancel_Click"/>
                <Button x:Name="btnSave" Content="SAVE" Width="90"  Click="btnSave_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>