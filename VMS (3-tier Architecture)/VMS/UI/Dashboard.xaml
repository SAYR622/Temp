<Page x:Class="VMS.UI.Dashboard"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:gmap="clr-namespace:GMap.NET.WindowsPresentation;assembly=GMap.NET.WindowsPresentation"
      Title="Dashboard" Loaded="Page_Loaded">

    <Grid Margin="25,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1.4*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <!-- ROW 0: WELCOME HEADER -->
        <Grid Grid.Row="0" Margin="5,0,0,15">
            <StackPanel VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Hello, Admin!" FontSize="20" FontWeight="Bold"/>
                </StackPanel>
                <TextBlock Text="Welcome back to Visitors Management System" FontSize="12" Foreground="#475569" Margin="0,2,0,0"/>
            </StackPanel>

            <Border HorizontalAlignment="Right" VerticalAlignment="Center" Background="White" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8" Padding="12,6">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📅" FontSize="12" Foreground="#64748B" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtCurrentDate" Text="..." FontSize="11" FontWeight="Medium" Foreground="#475569" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ROW 1: STATISTICS CARDS -->
        <UniformGrid Grid.Row="1" Columns="2" Margin="0,0,0,15">
            <Border Background="White" CornerRadius="12" Margin="5" Padding="14">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.08" Color="#000000"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="38" Height="38" Background="#EEF2FF" CornerRadius="19" VerticalAlignment="Center" Margin="0,0,10,0">
                        <TextBlock Text="🏛" FontSize="15" Foreground="#4F46E5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Total Heritage Sites" FontSize="11" Foreground="#64748B" FontWeight="Medium"/>
                        <TextBlock x:Name="txtTotalSites" Text="0" FontSize="19" FontWeight="Bold" Margin="0,1,0,1"/>
                        <TextBlock Text="Active Database" FontSize="10" Foreground="#10B981" FontWeight="Medium"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Background="White" CornerRadius="12" Margin="5" Padding="14">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.08" Color="#000000"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="38" Height="38" Background="#EFF6FF" CornerRadius="19" VerticalAlignment="Center" Margin="0,0,10,0">
                        <TextBlock Text="👥" FontSize="15" Foreground="#3B82F6" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Total Visitors Recorded" FontSize="11" Foreground="#64748B" FontWeight="Medium"/>
                        <TextBlock x:Name="txtTotalVisitors" Text="0" FontSize="19" FontWeight="Bold" Margin="0,1,0,1"/>
                        <TextBlock Text="Across all sites" FontSize="10" Foreground="#10B981" FontWeight="Medium"/>
                    </StackPanel>
                </Grid>
            </Border>
        </UniformGrid>

        <!-- ROW 2: MIDDLE CONTENT -->
        <Grid Grid.Row="2" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="1.5*"/>
            </Grid.ColumnDefinitions>

            <!-- Visitor Activities Table -->
            <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="15" Margin="0,0,8,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.06" Color="#000000"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Recent Visitors" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,20"/>
                    <DataGrid x:Name="dgRecentActivities" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column" BorderThickness="0" Background="Transparent" RowHeaderWidth="0" GridLinesVisibility="None">
                        <DataGrid.Resources>

                            <Style TargetType="{x:Type DataGridColumnHeader}">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#64748B"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="0,0,0,12"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#F1F5F9"/>
                            </Style>

                            <Style TargetType="{x:Type DataGridRow}">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Margin" Value="0,6,0,1"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>

                            <Style TargetType="{x:Type DataGridCell}">
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="Foreground" Value="#334155"/>
                                <Setter Property="Padding" Value="0,10,0,10"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                            </Style>

                        </DataGrid.Resources>

                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Visitor" Width="1.2*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Ellipse Width="10" Height="10" Fill="#CBD5E1" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding VisitorName}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Site Visited" Binding="{Binding Site}" Width="1.2*"/>
                            <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Map Card -->
            <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="15" Margin="8,0,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.06" Color="#000000"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="160"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Heritage Sites Map" FontSize="14" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,10"/>
                        <Border Grid.Row="1" Background="#F1F5F9" CornerRadius="10" ClipToBounds="True">
                            <gmap:GMapControl x:Name="MyMap"/>
                        </Border>
                    </Grid>

                    <StackPanel Grid.Column="1" Margin="12,28,0,0">
                        <!-- Dynamic ItemsControl mapping Top Sites to the side panel -->
                        <ItemsControl x:Name="icMapSites">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding siteName}" FontSize="11" FontWeight="SemiBold" Foreground="#0F172A" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding province}" FontSize="10" Foreground="#64748B"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ROW 3: BOTTOM CONTENT -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <!-- Active Admins Card -->
            <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="15" Margin="0,0,8,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.06" Color="#000000"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Active Admins" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,10"/>

                    <ItemsControl x:Name="icActiveAdmins">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="32" Height="32" Background="#E0E7FF" CornerRadius="16">
                                        <TextBlock Text="👤" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#4F46E5"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding FullName}" FontSize="11" FontWeight="Medium" Foreground="#0F172A"/>
                                        <TextBlock Text="{Binding Role}" FontSize="10" Foreground="#64748B" Margin="0,1,0,0"/>
                                    </StackPanel>
                                    <Border Grid.Column="2" Background="{Binding StatusBg}" CornerRadius="6" Padding="6,3" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding StatusText}" FontSize="9" Foreground="{Binding StatusColor}" FontWeight="Bold"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Top Visited Sites Card -->
            <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="15" Margin="8,0,8,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.06" Color="#000000"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Top Visited Sites" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,10"/>

                    <ItemsControl x:Name="icTopVisitedSites">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,12">
                                    <Grid Margin="0,0,0,4">
                                        <TextBlock Text="{Binding SiteName}" FontSize="11" Foreground="#475569" FontWeight="Medium"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding VisitorsCount}" FontSize="11" Foreground="#0F172A" FontWeight="Bold"/>
                                            <TextBlock Text=" visitors" FontSize="10" Foreground="#94A3B8" VerticalAlignment="Bottom" Margin="2,0,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                    <ProgressBar Value="{Binding Percentage}" Height="6" Foreground="{Binding BarColor}" Background="#E2E8F0" BorderThickness="0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Quick Actions Grid Card -->
            <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="12" Margin="8,0,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.06" Color="#000000"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Quick Actions" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A" Margin="0,0,0,6"/>
                    <Grid Grid.Row="1" Margin="0,10,0,0" Height="127" VerticalAlignment="Top">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="1*"/>
                            <RowDefinition Height="1*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Row="0" Grid.Column="0" Margin="4" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Height="Auto" Width="Auto"
                          Click="btnQuickAddSite_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="{x:Type Button}">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="🏛" FontSize="14" Foreground="#4F46E5" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                            <TextBlock Text="Add New Site" FontSize="10" Foreground="#334155" HorizontalAlignment="Center" FontWeight="Medium"/>
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Grid.Row="0" Grid.Column="1" Margin="4" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Height="Auto" Width="Auto">
                            <Button.Template>
                                <ControlTemplate TargetType="{x:Type Button}">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="✉" FontSize="14" Foreground="#F59E0B" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                            <TextBlock Text="Send Email" FontSize="10" Foreground="#334155" HorizontalAlignment="Center" FontWeight="Medium" />
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="4" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" Height="Auto" Width="Auto" Click="btnQuickAddAdmin_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="{x:Type Button}">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="🛡" FontSize="14" Foreground="#EC4899" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                            <TextBlock Text="Add Admin" FontSize="10" Foreground="#334155" HorizontalAlignment="Center" FontWeight="Medium"/>
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>