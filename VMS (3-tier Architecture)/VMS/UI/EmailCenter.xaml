<Page x:Class="CHSMS.UI.EmailCenter"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="EmailCenter" Background="#F8FAFC">

    <TabControl Background="Transparent" BorderThickness="0" Margin="10">
        <TabControl.Resources>
            <SolidColorBrush x:Key="PrimaryHueMidBrush" Color="Black"/>
        </TabControl.Resources>

        <TabItem Header="Custom Emails" FontSize="16" FontWeight="SemiBold" Padding="15,10">
            <Grid Margin="10,20,10,10">

                <Grid x:Name="VisitorSelectionView">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Custom Emails" FontSize="25" FontWeight="Bold"/>
                            <TextBlock Text="Select visitors and send custom announcements." FontSize="14" Foreground="#718096" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Site:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="14" FontWeight="SemiBold"/>
                            <ComboBox x:Name="SiteFilterComboBox" Width="150" FontSize="14" Padding="5" SelectionChanged="Filters_SelectionChanged" DisplayMemberPath="siteName" SelectedValuePath="Id" />

                            <TextBlock Text="Time:" VerticalAlignment="Center" Margin="20,0,10,0" FontSize="14" FontWeight="SemiBold"/>
                            <ComboBox x:Name="TimeFilterComboBox" Width="150" FontSize="14" Padding="5" SelectionChanged="Filters_SelectionChanged" SelectedIndex="0">
                                <ComboBoxItem Content="Last 24 Hours"/>
                                <ComboBoxItem Content="All Time"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <DataGrid x:Name="VisitorsTable" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" Background="White" RowHeight="35" FontSize="14" BorderBrush="#E2E8F0" BorderThickness="1">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="70">
                                <DataGridCheckBoxColumn.Header>
                                    <CheckBox x:Name="chkSelectAll" Content="All" Checked="chkSelectAll_Checked" Unchecked="chkSelectAll_Unchecked"/>
                                </DataGridCheckBoxColumn.Header>
                            </DataGridCheckBoxColumn>
                            <DataGridTextColumn Header="Email Address" Binding="{Binding Email}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Visit Date" Binding="{Binding VisitDate, StringFormat=\{0:MMM dd\, yyyy - hh:mm tt\}}" Width="200" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Button Grid.Row="2" Content="Write Custom Email to Selected" Margin="0,20,0,0" MinHeight="50" Background="#284A9D" BorderBrush="#284A9D" Foreground="White" FontSize="16" FontWeight="Bold" Click="btnOpenCampaignEditor_Click"/>
                </Grid>

                <Grid x:Name="CampaignComposeView" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Text="Compose The Email" FontSize="20" FontWeight="Bold"/>
                        <TextBox x:Name="txtCampaignSubject" 
                          FontSize="16" 
                          Padding="8" 
                          Margin="0,10,0,0" 
                          BorderBrush="#E2E8F0" 
                          BorderThickness="1" 
                          materialDesign:HintAssist.Hint="Subject..."/>
                    </StackPanel>

                    <Border Grid.Row="1" BorderBrush="#E2E8F0" BorderThickness="1" Background="White">
                        <wv2:WebView2 x:Name="CampaignWebView"/>
                    </Border>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button Content="Cancel" Width="200" MinHeight="45" Margin="0,0,10,0" Background="#94A3B8" BorderThickness="0" Foreground="White" FontSize="16" FontWeight="Bold" Click="btnCancelCampaign_Click"/>
                        <Button x:Name="btnSendCampaign" Content="Send Emails" Width="200" MinHeight="45" Background="#10B981" BorderThickness="0" Foreground="White" FontSize="16" FontWeight="Bold" Click="btnSendCampaign_Click"/>
                    </StackPanel>
                </Grid>

            </Grid>
        </TabItem>

        <TabItem Header="Automated Templates" FontSize="16" FontWeight="SemiBold" Padding="15,10">
            <Grid Margin="10,20,10,10">

                <Grid x:Name="TemplateEditorView">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Text="Default Email Templates" FontSize="24" FontWeight="Bold"/>
                        <TextBlock Text="Edit the automated HTML emails sent when a QR code is scanned." FontSize="14" Foreground="#718096"/>
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <ComboBox x:Name="TemplateSelector" Width="180" FontSize="14" Padding="5" SelectionChanged="TemplateSelector_SelectionChanged" Margin="0,0,15,0" DisplayMemberPath="siteName" SelectedValuePath="Id" />
                            <TextBlock Text="Subject:" VerticalAlignment="Center" FontWeight="Bold" FontSize="14" Margin="0,0,10,0"/>
                            <TextBox x:Name="txtTemplateSubject" Width="300" FontSize="14" Padding="5"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="btnSaveTemplate" Content="💾 Save" Margin="10,0,0,0" Padding="15,5" Background="#4CAF50" BorderBrush="#4CAF50" Foreground="White" FontWeight="Bold" Click="btnSaveTemplate_Click"/>
                            <Button Content="🖼️ Upload" Margin="10,0,0,0" Padding="15,5" Background="#2196F3" BorderBrush="#2196F3" Foreground="White" FontWeight="Bold" Click="btnUploadImage_Click"/>
                            <Button Content="📚 Library" Margin="10,0,0,0" Padding="15,5" Background="#673AB7" BorderBrush="#673AB7" Foreground="White" FontWeight="Bold" Click="btnOpenLibrary_Click"/>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="2" BorderBrush="#E2E8F0" BorderThickness="1" Background="White">
                        <wv2:WebView2 x:Name="TemplateWebView"/>
                    </Border>
                </Grid>

                <Grid x:Name="ImageLibraryView" Visibility="Collapsed" Background="White">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <DockPanel Grid.Column="0" Margin="0,0,20,0">
                        <TextBlock DockPanel.Dock="Top" Text="Available Images" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        <ListBox x:Name="ImageListBox" SelectionChanged="ImageListBox_SelectionChanged" DisplayMemberPath="Name" BorderBrush="#E2E8F0"/>
                    </DockPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Preview" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Border BorderBrush="#E2E8F0" BorderThickness="1" Background="#F1F5F9" Height="300">
                            <Image x:Name="PreviewImage" Stretch="Uniform"/>
                        </Border>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                            <Button Content="Cancel" Width="100" Margin="0,0,10,0" Background="#94A3B8" Foreground="White" Click="btnCancelLibrary_Click"/>
                            <Button Content="Insert Image" Width="150" MinHeight="40" Background="#284A9D" Foreground="White" FontWeight="Bold" Click="btnInsertImage_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

            </Grid>
        </TabItem>
    </TabControl>
</Page>