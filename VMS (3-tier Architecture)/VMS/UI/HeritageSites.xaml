<Page x:Class="VMS.UI.HeritageSites"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:gmap="clr-namespace:GMap.NET.WindowsPresentation;assembly=GMap.NET.WindowsPresentation"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">


    <Grid Background="#F8FAFC"
          Margin="20">


        <Grid.RowDefinitions>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>




        <!-- TITLE -->

        <TextBlock Grid.Row="0"
                   Text="Heritage Sites Management"
                   FontSize="28"
                   FontWeight="Bold"
                   Margin="0,-13,0,33"/>
        
        <TextBlock Text="Manage the central database of all cultural heritage locations." FontSize="14" Foreground="#718096" Margin="1,29,-1,91" Grid.RowSpan="2"/>





        <!-- SEARCH -->

        <Border Grid.Row="1"
        Background="White"
        CornerRadius="12"
        Padding="15"
        Margin="0,0,0,20">

            <!-- Added a subtle shadow to match your dashboard cards perfectly -->
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.06" Color="#000000"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- PROPER SEARCH BAR: Uses Hint instead of hardcoded Text -->
                <TextBox x:Name="txtSearchSite"
                 Height="40"
                 VerticalContentAlignment="Center"
                 materialDesign:HintAssist.Hint="Search Heritage Site..."
                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                 Margin="5,0,20,0"
                 BorderBrush="Black"
                 CaretBrush="Black"
                 materialDesign:HintAssist.Foreground="Black"
                 materialDesign:TextFieldAssist.UnderlineBrush="Black"
                 TextChanged="txtSearchSite_TextChanged"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">

                    <!-- PROPER ADD BUTTON: Uses Material Design Vector Icon -->
                    <Button x:Name="btnAddSite"
                    Width="105" Height="40" Margin="5"
                    Background="#22C55E" BorderBrush="#22C55E"
                    Click="btnAddSite_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Add" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <!-- PROPER UPDATE BUTTON: Uses Material Design Vector Icon -->
                    <Button x:Name="btnUpdateSite"
                    Width="105" Height="40" Margin="5"
                    Background="#3B82F6" BorderBrush="#3B82F6"
                    Click="btnUpdateSite_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Pencil" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Update" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <!-- PROPER DELETE BUTTON: Uses Material Design Vector Icon -->
                    <Button x:Name="btnDeleteSite"
                    Width="105" Height="40" Margin="5"
                    Background="#EF4444" BorderBrush="#EF4444"
                    Click="btnDeleteSite_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="TrashCan" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Delete" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </Grid>
        </Border>



        <!-- MAIN AREA -->


        <Grid Grid.Row="2">


            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="1.3*"/>

                <ColumnDefinition Width="1*"/>


            </Grid.ColumnDefinitions>








            <!-- TABLE -->


            <Border Background="White"
                    CornerRadius="15"
                    Padding="15"
                    Margin="0,0,15,0">



                <DataGrid x:Name="dgSites"
                  AutoGenerateColumns="False"
                  SelectionChanged="dgSites_SelectionChanged"
                  IsReadOnly="True" 
                  HeadersVisibility="Column" 
                  Background="White" 
                  BorderBrush="#E2E8F0" 
                  RowBackground="#FFFFFF" 
                  AlternatingRowBackground="#F7FAFC">   

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="ID"
                            Binding="{Binding Id}"
                            Width="50"/>

                        <DataGridTextColumn Header="Site Name"
                            Binding="{Binding siteName}"
                            Width="214"/>

                        <DataGridTextColumn Header="Province"
                            Binding="{Binding province}"
                            Width="130"/>

                        <DataGridTextColumn Header="Visitors"
                            Binding="{Binding visitors}"
                            Width="100"/>

                    </DataGrid.Columns>

                </DataGrid>



            </Border>









            <!-- MAP -->


            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="15"
                    Padding="10">


                <gmap:GMapControl x:Name="heritageMap"/>


            </Border>





        </Grid>



    </Grid>


</Page>