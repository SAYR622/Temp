<Window x:Class="VMS.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:VMS"
        mc:Ignorable="d"
        Icon="/Images/logo2.png"
        Title="login" Height="760" Width="450"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        SnapsToDevicePixels="True" 
        UseLayoutRounding="True">


    <materialDesign:Card UniformCornerRadius="15" Margin="25" materialDesign:ElevationAssist.Elevation="Dp4">
        <StackPanel>
            <Button Margin="335 12 0 0" x:Name="closeBtn" Width="43" Height="43" FontSize="13" FontFamily="Comic Sans MS" Content="X" Style="{DynamicResource MaterialDesignFlatMidBgButton}"  materialDesign:ElevationAssist.Elevation="Dp0" materialDesign:ButtonAssist.CornerRadius="20" Click="closeBtn_Click" FontWeight="Bold"
              BorderBrush="Transparent"/>
            <Image Height="150" Margin="0 40 0 20" Source="/Images/logo.png" RenderOptions.BitmapScalingMode="Fant"/>
            <TextBlock Margin="0 0 0 2" HorizontalAlignment="Center" FontSize="25" FontWeight="Bold" Text="Welcome Back!"/>
            <TextBlock FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"  Text="Log into your existing account"/>

            <TextBox Margin="0 50 0 0" x:Name="txtUsername" Width="250" FontSize="14" 

              materialDesign:HintAssist.Hint="Enter Username" 
              Style="{DynamicResource MaterialDesignFloatingHintTextBox}"
              Background="#00000000"
              PreviewKeyDown="Input_PreviewKeyDown"/>

            <PasswordBox Margin="0 20 0 0" x:Name="txtPassword" Width="250" FontSize="14" 
              materialDesign:HintAssist.Hint="Enter Password" 
              Style="{DynamicResource MaterialDesignFloatingHintPasswordBox}"
              Background="#00000000"
              PreviewKeyDown="Input_PreviewKeyDown"/>

            <Button Margin="0 60 0 0" 
            x:Name="loginBtn" 
            Width="200" Height="53" 
            Foreground="White" 
            FontSize="12" 
            Content="LOG IN" 
            Style="{DynamicResource MaterialDesignFlatMidBgButton}"  
            materialDesign:ElevationAssist.Elevation="Dp0" 
            materialDesign:ButtonAssist.CornerRadius="10" 
            Click="loginBtn_Click"
            BorderBrush="Transparent"
            IsDefault="True"/>

            <Button Margin="0 5 0 0" 
            x:Name="createBtn" 
            Width="190" Height="25" 
            Background="White" 
            Foreground="#FF284A9D" 
            FontSize="12" 
            Content="Request an account" 
            BorderBrush="Transparent"
            Click="createBtn_Click"
            materialDesign:ElevationAssist.Elevation="Dp0"
            FontWeight="Bold"/>

        </StackPanel>
    </materialDesign:Card>
</Window>