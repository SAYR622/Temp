<Window x:Class="VMS.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/Images/logo2.png"
        Title="VMS Dashboard"
        Height="750"
        Width="1250"
        WindowStartupLocation="CenterScreen"
        Background="#E2E8F0">

    <Window.Resources>
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="80"/>
            <Setter Property="Margin" Value="15,4"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="15,0,10,0">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E293B"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0F172A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LogoutButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="45"/>

            <Setter Property="Margin" Value="15,4"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#F87171"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="15,0,10,0">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#EF4444"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#DC2626"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#0F172A" Margin="-1,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,30,0,30">
                    <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Center" 
                        Margin="0,0,0,5">

                        <Image Source="/Images/logo.png"
                           Width="30" 
                           Height="30" 
                           Margin="0,0,10,0" 
                           RenderOptions.BitmapScalingMode="HighQuality"/>

                        <TextBlock Text="VMS"
                           Foreground="White"
                           FontSize="30"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="VISITORS MANAGEMENT" 
                       Foreground="#475569" 
                       FontSize="9" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,0"/>
                </StackPanel>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <Button x:Name="btnDashboard"
                                Style="{StaticResource SidebarButtonStyle}"
                                Content="📈   Dashboard"
                                Foreground="White"
                                Background="#1E293B"
                                Click="btnDashboard_Click"/>

                        <Button x:Name="btnHeritageSites"
                                Style="{StaticResource SidebarButtonStyle}"
                                Content="🏛   Heritage Sites"
                                Click="btnHeritageSites_Click"/>

                        <Button x:Name="btnVisitors"
                                Style="{StaticResource SidebarButtonStyle}"
                                Content="👥   Visitors"
                                Click="btnVisitors_Click"/>

                        <Button x:Name="btnEmailCenter"
                                Style="{StaticResource SidebarButtonStyle}"
                                Content="📧   Email Center"
                                Click="btnEmailCenter_Click"/>

                        <Button x:Name="btnAdminManage"
                                Style="{StaticResource SidebarButtonStyle}"
                                Content="🛡   Admins Manage"
                                Click="btnAdminManage_Click"
                                Visibility="Collapsed"/>

                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,0,0,15">
                        <Border Height="1" 
                                Background="#1E293B" 
                                Margin="20,10,20,10"/>

                        <Button x:Name="btnLogout" Margin="0,0,10,0"
                                Style="{StaticResource LogoutButtonStyle}"
                                Content="🚪   Logout  "
                                Click="btnLogout_Click"
                                HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="15,15,25,15">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">


                        <TextBlock Text="  Visitors Management System" FontSize="16" FontWeight="SemiBold" Foreground="#1E293B" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">

                        <Button x:Name="btnNotifications" Visibility="Collapsed" Click="btnNotifications_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,20,0">
                            <Grid>
                                <TextBlock Text="🔔" FontSize="18" Foreground="#64748B" VerticalAlignment="Center"/>
                                <Border x:Name="NotificationBadge" Background="#EF4444" CornerRadius="6" Width="12" Height="12" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8,-2,0,0">
                                    <TextBlock x:Name="txtNotificationCount" Text="0" FontSize="8" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Button>

                        <Popup x:Name="NotificationPopup" PlacementTarget="{Binding ElementName=btnNotifications}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                            <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Margin="0,10,10,10" Width="280" MaxHeight="350">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="15" Color="Black" Opacity="0.1" ShadowDepth="4"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                                        <TextBlock Text="Recent Account Requests" FontWeight="Bold" FontSize="13" Padding="15,12"/>
                                    </Border>

                                    <ListBox x:Name="listAdminRequests" Grid.Row="1" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Padding="5">
                                                    <StackPanel Margin="5">
                                                        <TextBlock Text="{Binding FullName}" FontWeight="SemiBold" FontSize="13" Foreground="#1E293B"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                            <TextBlock Text="📞 " FontSize="10" Foreground="#64748B"/>
                                                            <TextBlock Text="{Binding Contact}" FontSize="11" Foreground="#64748B"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding TimeReceived}" FontSize="10" Foreground="#94A3B8" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>
                        </Popup>

                        <Button x:Name="btnProfile" Click="btnProfile_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" Height="40">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="32" Height="32" CornerRadius="16" Margin="0,0,10,0" Background="#CBD5E1">
                                    <TextBlock Text="👤" FontSize="16" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="6,4,0,0"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="txtAdminName" Text="Loading..." FontSize="12" FontWeight="SemiBold" Foreground="#1E293B"/>
                                    <TextBlock x:Name="txtAdminRole" Text="" FontSize="10" Foreground="#94A3B8"/>
                                </StackPanel>
                            </StackPanel>
                        </Button>

                        <Popup x:Name="ProfilePopup" PlacementTarget="{Binding ElementName=btnProfile}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                            <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Margin="0,10,10,10" Width="180">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="15" Color="Black" Opacity="0.1" ShadowDepth="4"/>
                                </Border.Effect>

                                <StackPanel Margin="5">
                                    <Button Content="⚙️ Account Settings" Click="btnAccountSettings_Click" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left" Padding="10,6" Cursor="Hand" Foreground="#1E293B"/>
                                    <Border Height="1" Background="#E2E8F0" Margin="5"/>
                                    <Button Content="🚪 Logout" Click="btnLogout_Click" Foreground="#EF4444" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left" Padding="10,6" Cursor="Hand"/>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.Background>
                    <DrawingBrush TileMode="Tile" Viewport="0,0,16,16" ViewportUnits="Absolute">
                        <DrawingBrush.Drawing>
                            <DrawingGroup>
                                <GeometryDrawing Brush="#F8FAFC">
                                    <GeometryDrawing.Geometry>
                                        <RectangleGeometry Rect="0,0,16,16"/>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                                <GeometryDrawing Brush="#CBD5E1">
                                    <GeometryDrawing.Geometry>
                                        <EllipseGeometry Center="2,2" RadiusX="0.75" RadiusY="0.75"/>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                            </DrawingGroup>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Grid.Background>

                <Frame x:Name="MainFrame"
                       NavigationUIVisibility="Hidden"
                       Background="Transparent"/>
            </Grid>
        </Grid>
    </Grid>
</Window>