<Window x:Class="VMS.UI.RequestAccount"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Icon="/Images/logo2.png"
        Title="Create Account - VMS" Height="600" Width="450" 
        WindowStartupLocation="CenterScreen" Background="#F4F6FA">

    <!-- Main Container with Drop Shadow effect -->
    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <Border Background="White" CornerRadius="15" Width="380" Padding="30">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Color="#D3D3D3" ShadowDepth="2" Direction="270" Opacity="0.7"/>
            </Border.Effect>

            <StackPanel>
                <!-- Professional Header -->
                <TextBlock Text="Request an Account" FontSize="26" FontWeight="Bold" Foreground="#1E2A4A" HorizontalAlignment="Center" Margin="0,0,0,25"/>
                

                <!-- Full Name -->
                <TextBlock Text="Full Name" FontSize="12" FontWeight="SemiBold" Foreground="#1E2A4A" Margin="0,0,0,5"/>
                <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Margin="0,0,0,15">
                    <TextBox x:Name="txtFullName" 
                     Height="30" 
                     Padding="10,0" 
                     VerticalContentAlignment="Center" 
                     BorderThickness="0" 
                     Background="Transparent" 
                     FontSize="14" 
                     Foreground="#1E2A4A"
                     Style="{x:Null}"/>     
                </Border>

                <!-- Username -->
                <TextBlock Text="Username" FontSize="12" FontWeight="SemiBold" Foreground="#1E2A4A" Margin="0,0,0,5"/>
                <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Margin="0,0,0,15">
                    <TextBox x:Name="txtUsername" 
                     Height="30" 
                     Padding="10,0" 
                     VerticalContentAlignment="Center" 
                     BorderThickness="0" 
                     Background="Transparent" 
                     FontSize="14" 
                     Foreground="#1E2A4A"
                     Style="{x:Null}"/> 
                </Border>

                <!-- Password -->
                <TextBlock Text="Password" FontSize="12" FontWeight="SemiBold" Foreground="#1E2A4A" Margin="0,0,0,5"/>
                <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Margin="0,0,0,15">
                    <PasswordBox x:Name="txtPassword" 
                     Height="30" 
                     Padding="10,0" 
                     VerticalContentAlignment="Center" 
                     BorderThickness="0" 
                     Background="Transparent" 
                     FontSize="14" 
                     Foreground="#1E2A4A"
                     Style="{x:Null}"/>
                </Border>

                <!-- Contact -->
                <TextBlock Text="Contact Number" FontSize="12" FontWeight="SemiBold" Foreground="#1E2A4A" Margin="0,0,0,5"/>
                <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Margin="0,0,0,15">
                    <TextBox x:Name="txtContact" 
                     Height="30" 
                     Padding="10,0" 
                     VerticalContentAlignment="Center" 
                     BorderThickness="0" 
                     Background="Transparent" 
                     FontSize="14" 
                     Foreground="#1E2A4A"
                     Style="{x:Null}"/>
                </Border>

                <!-- Gender -->
                <TextBlock Text="Gender" FontSize="12" FontWeight="SemiBold" Foreground="#1E2A4A" Margin="0,0,0,5"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                    <RadioButton x:Name="rbMale" Content="Male" IsChecked="True" GroupName="Gender" FontSize="13" Foreground="#1E2A4A" Margin="0,0,20,0" Style="{x:Null}"/>
                    <RadioButton x:Name="rbFemale" Content="Female" GroupName="Gender" FontSize="13" Foreground="#1E2A4A" Style="{x:Null}"/>
                </StackPanel>

                <!-- Create Account Button -->
                <Button x:Name="btnRequest" Click="btnRequestAccount_Click" Cursor="Hand" Height="45">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#1E2A4A" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <ContentPresenter.Content>
                                        <TextBlock Text="Request" Foreground="White" FontSize="14" FontWeight="Bold"/>
                                    </ContentPresenter.Content>
                                </ContentPresenter>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>