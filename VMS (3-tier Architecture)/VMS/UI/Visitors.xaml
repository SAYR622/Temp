<Page x:Class="VMS.UI.Visitors"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="Visitors" Loaded="Page_Loaded">

    <Grid Background="#F8FAFC" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="200"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Visitor Tracking &amp; Analytics" FontSize="28" FontWeight="Bold"/>
            <TextBlock Text="Monitor visitor activities, trends, and statistics." FontSize="14" Foreground="#718096" Margin="0,5,0,15"/>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Select Heritage Site:" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"  Margin="0,0,10,0"/>
                <ComboBox x:Name="cmbSites" 
                          Width="250" 
                          Height="35" 
                          DisplayMemberPath="siteName" 
                          SelectedValuePath="Id"
                          SelectionChanged="cmbSites_SelectionChanged"
                          BorderBrush="Black"
                          materialDesign:TextFieldAssist.UnderlineBrush="Black"/>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Visitor Log" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>

                <DataGrid x:Name="VisitorsDataGrid" Grid.Row="1" AutoGenerateColumns="False" 
                          IsReadOnly="True" HeadersVisibility="Column" Background="White" 
                          BorderBrush="#E2E8F0" RowBackground="#FFFFFF" AlternatingRowBackground="#F7FAFC">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding VisitorId}" Width="80"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
                        <DataGridTextColumn Header="Date Visited" Binding="{Binding VisitDate, StringFormat=dd/MM/yyyy HH:mm}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="15">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Top" 
                   Text="Recent Visitor Trends" 
                   FontSize="16" 
                   FontWeight="SemiBold" 
                   Margin="0,0,0,10"/>

                <ScottPlot:WpfPlot x:Name="VisitorChart" 
                           VerticalAlignment="Stretch" 
                           HorizontalAlignment="Stretch"/>
            </DockPanel>
        </Border>

    </Grid>
</Page>